# ── App ───────────────────────────────────────────────────────────────
APP_NAME="Meezan API"
APP_VERSION="1.0.0"
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────
# Local dev uses docker-compose postgres; production uses Supabase pooler URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/meezan

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Found in Supabase dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# ── External APIs ─────────────────────────────────────────────────────
# https://goldapi.io — free tier, live gold/silver prices
GOLD_API_KEY=your-goldapi-key

# https://financialmodelingprep.com — stock fundamentals for Shariah screening
FMP_API_KEY=your-fmp-key

# https://www.alphavantage.co — additional stock data
ALPHA_VANTAGE_KEY=your-alpha-vantage-key

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000
